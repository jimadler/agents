#!/bash/sh

eval "$(/opt/homebrew/bin/brew shellenv zsh)"
export PATH="$HOME/.local/bin:$PATH"
export PATH="$PATH:/Users/jim/Library/Application Support/JetBrains/Toolbox/scripts"

# python
export PATH="/opt/homebrew/opt/python@3.14/bin:$PATH"
alias python="python3"
alias pip="pip3"

# Allow command substitution inside the prompt string
setopt prompt_subst

# Native zsh function to fetch the git branch
get_git_branch() {
    local branch=$(git branch 2>/dev/null | grep '^*' | sed 's/* //')
    if [[ -n "$branch" ]]; then
        echo "%F{red}($branch)%f "
    fi
}
update_prompt() {
    # Define colors and system info using zsh escape sequences
    local user_host="%F{green}%n@%m%f"
    local cur_location="%F{blue}%~%f"
    local prompt_tail="%F{magenta}>%f "
    
    # Build the core prompt
    PROMPT="$user_host $cur_location \$(get_git_branch)$prompt_tail"
    
    # Add Python Virtual Environment prefix if active
    if [[ -n "$VIRTUAL_ENV" ]]; then
        PROMPT="(${VIRTUAL_ENV:t}) $PROMPT"
    fi
}

# Run the function before every prompt render
autoload -Uz add-zsh-hook
add-zsh-hook precmd update_prompt

# directory colors (add the following to ~/.bash_profile: source ~/.bashrc)
export CLICOLOR=1
export LSCOLORS=ExFxBxDxCxegedabagacad

# hermes
. "$HOME/.local/bin/env"

# aliases
alias wrapon='tput smam' && alias wrapoff='tput rmam'
alias pa='pyenv activate' && alias pd='pyenv deactivate'
alias nga="ngrok tcp 5900"
alias cda="cd '/Users/jim/Projects/agents'"
